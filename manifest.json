{
  "manifest_version": 3,
  "name": "MF勤怠グループチェック",
  "version": "1.0.4",
  "description": "マネーフォワード勤怠の従業員プルダウンで、事前にグループ分けした従業員を一括選択できる拡張機能です。フロア別・チーム別の勤怠確認がワンクリックで完了します。",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MF勤怠グループチェック",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://attendance.moneyforward.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
